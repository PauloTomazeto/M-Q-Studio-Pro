# ============================================
# SUPABASE CONFIGURATION (Required for uploads)
# ============================================
# Get these from: https://app.supabase.com/project/[project-id]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_STORAGE_BUCKET_NAME=user-uploads

# ============================================
# AI / GENERATION SERVICES
# ============================================
# KIE AI API Key - Required for image generation features
# Get your key at: https://kie.ai/api-key
# This is a sensitive credential and must not be committed to version control
KIE_API_KEY=your_kie_api_key_here

# Google Gemini API Key - Optional for additional AI features
GEMINI_API_KEY=

# ============================================
# OPTIONAL CONFIGURATION
# ============================================
# API Base URL (for backend services)
VITE_API_BASE_URL=http://localhost:3000

# Feature Flags
VITE_DISABLE_HMR=false
VITE_DEBUG_MODE=false
